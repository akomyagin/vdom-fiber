{
  "name": "vdom-fiber",
  "version": "0.0.0",
  "description": "Мини-React с нуля: Virtual DOM + Fiber-подобный прерываемый планировщик рендеринга",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "virtual-dom",
    "vdom",
    "fiber",
    "reconciler",
    "scheduler",
    "react-clone",
    "education"
  ],
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
